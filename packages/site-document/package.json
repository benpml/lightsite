{
  "name": "@lightsite/site-document",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./renderer": "./src/renderer.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",

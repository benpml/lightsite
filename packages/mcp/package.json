{
  "name": "@handout/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/server.ts",
    "./remote": "./src/remote.ts"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "build": "tsc -p tsconfig.json --noEmit",

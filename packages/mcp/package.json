    "lint": "tsc -p tsconfig.json --noEmit",
    "smoke:descriptors": "tsx scripts/descriptor-smoke.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@handout/site-document": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2"
  }

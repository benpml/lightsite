{
  "name": "@lightsite/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:local": "node scripts/local-postgres.mjs",
    "db:migrate": "drizzle-kit migrate",
    "db:wait": "node scripts/wait-for-db.mjs",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@lightsite/config": "workspace:*",
    "@lightsite/site-document": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.8",
    "typescript": "~6.0.2"
  }
}

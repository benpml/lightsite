DATABASE_URL="postgres://postgres:postgres@localhost:5432/handout"
DATABASE_POOL_MAX="10"
NODE_ENV="development"
API_JSON_BODY_LIMIT="256kb"
TRUST_PROXY="false"
BETTER_AUTH_SECRET="change-me-at-least-32-characters-long"
RESEND_API_KEY="re_replace"
EMAIL_FROM="Handout <noreply@handout.link>"
TRACKING_SIGNING_SECRET="change-me-tracking-signing-secret-32-chars"
TRACKING_REPLAY_STORAGE="off"
TRACKING_RETENTION_MODE="in-process"
# Production replay storage:
# TRACKING_REPLAY_STORAGE="s3"
# TRACKING_REPLAY_S3_BUCKET="private-replay-bucket"
# TRACKING_REPLAY_S3_REGION="us-east-1"
# TRACKING_REPLAY_S3_ENDPOINT="https://s3-compatible-endpoint.example.com"
# TRACKING_REPLAY_S3_ACCESS_KEY_ID="..."
# TRACKING_REPLAY_S3_SECRET_ACCESS_KEY="..."
# TRACKING_REPLAY_S3_FORCE_PATH_STYLE="false"
# TRACKING_REPLAY_S3_KEY_PREFIX="handout"
BETTER_AUTH_URL="http://localhost:5173"
API_PORT="3011"
WEB_ORIGIN="http://localhost:5173"
WEB_ORIGINS="http://localhost:5173"
PUBLIC_SITE_ORIGIN="http://localhost:3011"
VITE_PUBLIC_SITE_ORIGIN="http://localhost:3011"
LOGO_DEV_TOKEN="replace-with-logo-dev-token"
STRIPE_SECRET_KEY="sk_test_replace"
STRIPE_WEBHOOK_SECRET="whsec_replace"
STRIPE_CORE_MONTHLY_PRICE_ID="price_core_monthly_replace"
STRIPE_CORE_ANNUAL_PRICE_ID="price_core_annual_replace"
STRIPE_PRO_MONTHLY_PRICE_ID="price_pro_monthly_replace"
STRIPE_PRO_ANNUAL_PRICE_ID="price_pro_annual_replace"
VITE_API_ORIGIN=""
HANDOUT_API_PROXY_TARGET="http://localhost:3011"
VITE_GIPHY_API_KEY="replace-with-giphy-web-sdk-key"
AUTOMATIONS_ENABLED=false
# Generate once with: openssl rand -base64 32
AUTOMATIONS_ENCRYPTION_KEY=
AUTOMATIONS_WORKER_MODE=in-process
# Development-only local webhook receiver support. Production rejects this value.
AUTOMATIONS_ALLOW_LOCAL_DESTINATIONS=false

{
  "name": "@handout/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit && tsup",
    "start": "pnpm --filter @handout/db db:migrate && node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "tracking:retention": "tsx scripts/tracking-retention.ts",
    "tracking:load": "tsx scripts/tracking-load.ts",
    "automations:worker": "tsx scripts/automation-worker.ts",
    "smoke:tracking": "tsx scripts/tracking-smoke.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@handout/mcp": "workspace:*",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@better-auth/drizzle-adapter": "^1.3.34",
    "@hocuspocus/server": "^4.3.0",
    "@handout/config": "workspace:*",
    "@handout/content-schema": "workspace:*",
    "@handout/contracts": "workspace:*",
    "@handout/db": "workspace:*",
    "@handout/domain": "workspace:*",
    "@handout/site-document": "workspace:*",
    "@handout/tracking-schema": "workspace:*",
    "@rrweb/record": "2.1.0",
    "better-auth": "^1.3.34",
    "cors": "^2.8.5",
    "crossws": "^0.4.9",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^4.22.1",
    "playwright": "^1.61.1",
    "stripe": "^22.3.0",
    "yjs": "^13.6.31",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@hocuspocus/provider": "^4.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^24.12.3",
    "@types/supertest": "^6.0.3",
    "parse5": "^8.0.1",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.8"
  }
}

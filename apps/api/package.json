{
  "name": "@lightsite/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit && tsup",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "smoke:tracking": "tsx scripts/tracking-smoke.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.3.34",
    "@lightsite/config": "workspace:*",
    "@lightsite/content-schema": "workspace:*",
    "@lightsite/contracts": "workspace:*",
    "@lightsite/db": "workspace:*",
    "@lightsite/domain": "workspace:*",
    "@lightsite/tracking-schema": "workspace:*",
    "better-auth": "^1.3.34",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^4.22.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^24.12.3",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.8"
  }
}
